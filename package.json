{
  "name": "cuebitt.neocities.org",
  "version": "1.0.0",
  "description": "my Neocities website!",
  "scripts": {
    "dev": "servor src/ --reload --static",
    "lint": "biome lint --write ./src",
    "format": "biome format --write ./src && prettier --write ./src/**/*.html && prettier --write ./src/wikimaker-eta/partials/*.mjs --plugin=prettier-plugin-embed",
    "prepare": "husky"
  },
  "author": "cuebitt",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-embed": "^0.4.15",
    "servor": "^4.0.2"
  },
  "lint-staged": {
    "**/*.{css,js,mjs}": [
      "biome format --write"
    ],
    "**/*.{html}": [
      "prettier --write"
    ],
    "./src/wikimaker-eta/partials/*.mjs": [
      "prettier --write --plugin=prettier-plugin-embed"
    ],
    "**/*.{js,mjs}": [
      "biome lint --write"
    ]
  }
}
