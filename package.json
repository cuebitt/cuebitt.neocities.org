{
  "name": "cuebitt.neocities.org",
  "version": "1.0.0",
  "description": "my Neocities website!",
  "scripts": {
    "dev": "servor site/ --reload --static",
    "lint": "standard ./site --fix",
    "prepare": "husky",
    "stylelint": "stylelint --fix site/**/*.css",
    "format": "prettier --write site/**/*.{css,html}"
  },
  "author": "cuebitt",
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "servor": "^4.0.2",
    "standard": "^17.1.2",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.1"
  },
  "lint-staged": {
    "site/**/*.{css,html}": [
      "prettier --write"
    ],
    "site/**/*.{js}": [
      "standard --fix"
    ],
    "site/**/*.{css}": [
      "stylelint --fix"
    ]
  }
}
