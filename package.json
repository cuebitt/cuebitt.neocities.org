{
  "name": "cuebitt.neocities.org",
  "version": "1.0.0",
  "description": "my Neocities website!",
  "scripts": {
    "dev": "servor site/ --reload --static",
    "lint": "biome lint --write ./site",
    "format": "biome format --write ./site && prettier --write ./site/**/*.html",
    "prepare": "husky"
  },
  "author": "cuebitt",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "servor": "^4.0.2"
  },
  "lint-staged": {
    "**/*.{css,js,mjs}": [
      "biome format --write"
    ],
    "**/*.{html}": [
      "prettier --write"
    ],
    "**/*.{js,mjs}": [
      "biome lint --write"
    ]
  }
}
